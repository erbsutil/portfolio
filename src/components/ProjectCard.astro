---
/**
 * ProjectCard Component
 *
 * Displays a project or case study entry in a card format with role, year, outcome summary,
 * and technology stack. Extends BaseCard component with project-specific features including
 * an optional featured badge, status indicator, and automatic tech stack truncation.
 *
 * @component
 *
 * @example
 * ```astro
 * <ProjectCard
 *   title="E-commerce Platform Redesign"
 *   slug="ecommerce-redesign"
 *   outcomeSummary="Increased conversion rate by 45% and reduced cart abandonment"
 *   role="Lead Frontend Developer"
 *   year={2024}
 *   techStack={['React', 'TypeScript', 'Next.js', 'Tailwind CSS', 'Stripe']}
 *   featured={true}
 *   status="completed"
 * />
 * ```
 */

import BaseCard from "./BaseCard.astro";
import ForwardLink from "./ForwardLink.astro";

interface Props {
  /** Project title (displayed as card heading) */
  title: string;

  /** URL slug for the project (used to generate /projects/{slug} link) */
  slug: string;

  /** Brief summary of project outcomes or impact */
  outcomeSummary: string;

  /** Year the project was completed */
  year: number;

  /** Optional array of technologies used (displays max 4, shows "+N" for remaining) */
  techStack?: string[];

  /** Whether to display the featured badge (default: false) */
  featured?: boolean;

  /** Project status (default: 'completed') */
  status?: "completed" | "ongoing" | "archived";

  /** Whether this is a meta-project (portfolio itself) for special highlighting */
  isMeta?: boolean;
}

const {
  title,
  slug,
  outcomeSummary,
  year,
  techStack = [],
  status = "completed",
  isMeta = false,
} = Astro.props;

// Show max 4 tech tags to keep card clean and consistent
const displayTech = techStack.slice(0, 4);
const hasMoreTech = techStack.length > 4;

// Status display configuration
const statusConfig = {
  completed: { label: "Completed", class: "status--completed" },
  ongoing: { label: "Ongoing", class: "status--ongoing" },
  archived: { label: "Archived", class: "status--archived" },
};
const statusInfo = statusConfig[status];
---

<BaseCard
  href={`/projects/${slug}`}
  class:list={["project-card", { "project-card--meta": isMeta }]}
>
  <Fragment slot="meta">{year}</Fragment>

  <div slot="badge" class="card-badges">
    {isMeta && <span class="badge badge--featured">Featured Case</span>}
    {
      status !== "completed" && (
        <span class:list={["badge", `badge--${status}`]}>
          {statusInfo.label}
        </span>
      )
    }
  </div>

  <Fragment slot="title">{title}</Fragment>
  <Fragment slot="description">{outcomeSummary}</Fragment>

  {
    displayTech.length > 0 && (
      <div slot="tags" class="tags-list">
        {displayTech.map((tech) => (
          <span class="tag">{tech}</span>
        ))}
        {hasMoreTech && <span class="tag-more">+{techStack.length - 4}</span>}
      </div>
    )
  }

  <ForwardLink text="View case study" />
</BaseCard>

<style>
  .card-badges {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .card-badges:empty {
    display: none;
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .featured-badge svg {
    flex-shrink: 0;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
  }

  /* Level 1: Primary Accents (Blue) */
  .badge--featured {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Level 2: Activity & Status (Indigo) */
  .badge--ongoing {
    color: var(--color-status-ongoing);
    border-color: var(--color-status-ongoing);
  }

  /* Level 2: Muted Status */
  .badge--archived {
    color: var(--color-status-archived);
    border-color: var(--color-status-archived);
    opacity: 0.7;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* Level 4: Metadata (MutedBackground) */
  .tag {
    font-size: 0.6875rem;
    padding: 0.2rem 0.6rem;
    background: var(--color-bg-elevated);
    border-radius: 4px;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .tag-more {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    color: var(--color-text-muted);
  }
</style>
