---
/**
 * MetricVisualization Component
 *
 * A premium visualization component for project metrics.
 * Supports both circular PageSpeed-style indicators for scores (e.g., "100/100")
 * and standard text-based metrics.
 *
 * Features:
 * - Dynamic detection of Lighthouse-style scores
 * - Circular SVG progress bars with color-coding (Green/Orange/Red)
 * - Smooth transition animations
 * - Responsive grid layout
 */

interface Metric {
  label: string;
  value: string;
}

interface Props {
  metrics: Metric[];
  auditSource?: string;
  auditDate?: string;
}

const { metrics, auditSource, auditDate } = Astro.props;

/**
 * Parses a value string to determine if it's a Lighthouse score
 * Returns numeric score and max value if it matches "X/Y" format
 */
function parseScore(value: string) {
  const match = value.match(/^(\d+)\/(\d+)$/);
  if (match) {
    return {
      score: parseInt(match[1]),
      total: parseInt(match[2]),
    };
  }
  return null;
}

/**
 * Returns the CSS variable for the rating color based on score percentage
 */
function getRatingColor(percentage: number) {
  if (percentage >= 90) return "var(--color-rating-high)";
  if (percentage >= 50) return "var(--color-rating-medium)";
  return "var(--color-rating-low)";
}

const scoreMetrics = metrics.filter((m) => parseScore(m.value));
const textMetrics = metrics.filter((m) => !parseScore(m.value));
const showLighthouseRow = scoreMetrics.length > 0;
const showDivider = showLighthouseRow && textMetrics.length > 0;
---

<div class:list={["impact-section", { "impact-section--text-only": !showLighthouseRow }]}>
  {
    showLighthouseRow && (
      <div class="lighthouse-row">
        {scoreMetrics.map((metric) => {
          const scoreData = parseScore(metric.value)!;
          const percentage = (scoreData.score / scoreData.total) * 100;
          const radius = 32;
          const circumference = 2 * Math.PI * radius;
          const offset = circumference - (percentage / 100) * circumference;
          const color = getRatingColor(percentage);

          return (
            <div class="score-card">
              <div class="score-circle-container">
                <svg class="score-svg" viewBox="0 0 80 80">
                  <circle class="track" cx="40" cy="40" r={radius} />
                  <circle
                    class="progress"
                    cx="40"
                    cy="40"
                    r={radius}
                    stroke={color}
                    stroke-dasharray={circumference}
                    stroke-dashoffset={offset}
                  />
                </svg>
                <div class="score-text" style={`color: ${color}`}>
                  {scoreData.score}
                </div>
              </div>
              <span class="score-label">
                {metric.label.replace("Lighthouse ", "")}
              </span>
            </div>
          );
        })}
      </div>
    )
  }

  {
    textMetrics.length > 0 && (
      <div class="qualitative-metrics">
        {showDivider && <div class="divider" />}
        <div class="insights-grid">
          {textMetrics.map((metric) => (
            <div class="insight-item">
              <span class="insight-label">{metric.label}</span>
              <span class="insight-value">{metric.value}</span>
            </div>
          ))}
        </div>
      </div>
    )
  }

  {
    (auditSource || auditDate) && (
      <div class="audit-footer">
        <div class="audit-badge-container">
          <div class="audit-badge-item">
            <span class="audit-badge-label">Verification</span>
            <span class="audit-badge-value">{auditSource}</span>
          </div>
          <div class="audit-badge-item">
            <span class="audit-badge-label">Audit Date</span>
            <span class="audit-badge-value">{auditDate}</span>
          </div>
        </div>
      </div>
    )
  }
</div>

<style>
  .impact-section {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2.5rem 1.5rem;
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  /* No Lighthouse row: avoid extra gap and keep padding balanced */
  .impact-section--text-only {
    gap: 0;
    padding-top: 1.75rem;
    padding-bottom: 2rem;
  }

  /* Lighthouse Rows */
  .lighthouse-row {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    width: 100%;
    flex-wrap: wrap;
  }

  .score-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .score-circle-container {
    position: relative;
    width: 80px;
    height: 80px;
  }

  .score-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .track {
    fill: none;
    stroke: var(--color-border);
    stroke-width: 4.5;
  }

  .progress {
    fill: none;
    stroke-width: 5;
    stroke-linecap: round;
    transition: stroke-dashoffset 1s ease-out;
  }

  .score-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-mono, monospace);
  }

  .score-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Qualitative Section */
  .qualitative-metrics {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .divider {
    width: 100%;
    height: 1px;
    background: repeating-linear-gradient(
      90deg,
      var(--color-border),
      var(--color-border) 4px,
      transparent 4px,
      transparent 8px
    );
    opacity: 0.5;
  }

  .insights-grid {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    width: 100%;
  }

  .insight-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .insight-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .insight-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
  }

  /* Footer */
  .audit-footer {
    border-top: 1px solid var(--color-border);
    width: 100%;
    padding-top: 1.5rem;
    margin-top: 0.5rem;
  }

  .audit-badge-container {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .audit-badge-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .audit-badge-label {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .audit-badge-value {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .lighthouse-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1.5rem;
    }

    .insight-value {
      font-size: 1.5rem;
    }

    .insights-grid {
      gap: 2rem;
    }
  }
</style>
