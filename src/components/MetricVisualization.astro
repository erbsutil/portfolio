---
/**
 * MetricVisualization Component
 * 
 * A premium visualization component for project metrics.
 * Supports both circular PageSpeed-style indicators for scores (e.g., "100/100")
 * and standard text-based metrics.
 * 
 * Features:
 * - Dynamic detection of Lighthouse-style scores
 * - Circular SVG progress bars with color-coding (Green/Orange/Red)
 * - Smooth transition animations
 * - Responsive grid layout
 */

interface Metric {
  label: string;
  value: string;
}

interface Props {
  metrics: Metric[];
  auditSource?: string;
  auditDate?: string;
}

const { metrics, auditSource, auditDate } = Astro.props;

/**
 * Parses a value string to determine if it's a Lighthouse score
 * Returns numeric score and max value if it matches "X/Y" format
 */
function parseScore(value: string) {
  const match = value.match(/^(\d+)\/(\d+)$/);
  if (match) {
    return {
      score: parseInt(match[1]),
      total: parseInt(match[2])
    };
  }
  return null;
}

/**
 * Returns the CSS variable for the rating color based on score percentage
 */
function getRatingColor(percentage: number) {
  if (percentage >= 90) return 'var(--color-rating-high)';
  if (percentage >= 50) return 'var(--color-rating-medium)';
  return 'var(--color-rating-low)';
}
---

<div class="metrics-grid">
  {metrics.map((metric) => {
    const scoreData = parseScore(metric.value);
    
    if (scoreData) {
      const percentage = (scoreData.score / scoreData.total) * 100;
      const radius = 34;
      const circumference = 2 * Math.PI * radius;
      const offset = circumference - (percentage / 100) * circumference;
      const color = getRatingColor(percentage);

      return (
        <div class="metric-visual">
          <div class="score-circle-wrapper">
            <svg class="score-circle" viewBox="0 0 80 80">
              <!-- Background Track -->
              <circle 
                class="circle-track" 
                cx="40" cy="40" r={radius} 
                fill="none" 
                stroke="var(--color-border)" 
                stroke-width="5"
              />
              <!-- Progress Bar -->
              <circle 
                class="circle-progress" 
                cx="40" cy="40" r={radius} 
                fill="none" 
                stroke={color} 
                stroke-width="5"
                stroke-dasharray={circumference}
                stroke-dashoffset={offset}
                stroke-linecap="round"
                transform="rotate(-90 40 40)"
              />
            </svg>
            <div class="score-value" style={`color: ${color}`}>
              {scoreData.score}
            </div>
          </div>
          <div class="metric-label">{metric.label}</div>
        </div>
      );
    }

    return (
      <div class="metric-text">
        <div class="metric-value">{metric.value}</div>
        <div class="metric-label">{metric.label}</div>
      </div>
    );
  })}
  
  { (auditSource || auditDate) && (
    <div class="metrics-footer">
      {auditSource && <span class="audit-source">Source: {auditSource}</span>}
      {auditSource && auditDate && <span class="audit-separator">·</span>}
      {auditDate && <span class="audit-date">Date: {auditDate}</span>}
    </div>
  )}
</div>

<style>
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 2rem;
    padding: 2rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    margin-bottom: 2rem;
  }

  /* Score Visualization */
  .metric-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .score-circle-wrapper {
    position: relative;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .score-circle {
    width: 100%;
    height: 100%;
  }

  .circle-progress {
    transition: stroke-dashoffset 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .score-value {
    position: absolute;
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-mono, monospace);
  }

  /* Text Visualization */
  .metric-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem;
  }

  .metric-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }

  .metric-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .metrics-footer {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.8;
  }

  .audit-separator {
    opacity: 0.5;
  }

  @media (max-width: 600px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      padding: 1.5rem;
    }
    
    .metric-text {
      grid-column: span 2;
      align-items: center;
      text-align: center;
      border-top: 1px solid var(--color-border);
      padding-top: 1.5rem;
    }
  }

  @media (max-width: 400px) {
    .metrics-grid {
      grid-template-columns: 1fr;
    }
    .metric-text {
      grid-column: span 1;
    }
  }
</style>
